# ============================================================
# Discord Bot AI - Environment Configuration
# ============================================================
# IMPORTANT: Fill in all values marked with "YOUR_..._HERE"
# This file should NEVER be committed to version control!
# ============================================================

# ============================================================
# Discord Configuration (REQUIRED)
# ============================================================
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_APPLICATION_ID=YOUR_APPLICATION_ID_HERE

# ============================================================
# Gemini API Configuration (REQUIRED for Agent)
# ============================================================
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================================
# Riot Games API (OPTIONAL - for LoL/TFT tracking)
# ============================================================
# Get your key from https://developer.riotgames.com/
RIOT_API_KEY=YOUR_RIOT_API_KEY_HERE


# ============================================================
# Agent Configuration (optimized for 2GB RAM VM)
# ============================================================
# Maximum time (in minutes) before a task is forcefully terminated
AGENT_SESSION_TIMEOUT_MINUTES=10

# Maximum self-correction iterations per task
AGENT_MAX_RETRIES=3

# Maximum concurrent agent tasks (keep low for 2GB RAM)
AGENT_MAX_CONCURRENT_TASKS=2

# ============================================================
# Logging Configuration (OPTIONAL)
# ============================================================
# Valid values: Verbose, Debug, Information, Warning, Error, Fatal
LOG_LEVEL=Information
